  <!DOCTYPE html>
  <html>
  <head>
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

  <style>
  body {
    font-family: 'Segoe UI';
    background: #f4f6f9;
    padding: 20px;
  }

  /* HEADER */
  .header {
    display:flex;
    justify-content:space-between;
    margin-bottom:20px;
  }

  .title { font-size:26px; font-weight:600; }

  /* KPI */
  .kpi-container {
    display:grid;
    grid-template-columns: repeat(5,1fr);
    gap:10px;
    margin-bottom:20px;
  }

  .kpi {
    background:white;
    border-left:5px solid #0078d4;
    padding:10px;
    border-radius:8px;
  }

  .kpi small { color:#666; }
  .kpi strong { font-size:16px; }

  /* CHART GRID */
  .dashboard {
    display:grid;
    grid-template-columns: repeat(2,1fr);
    gap:20px;
  }

  .chart-box {
    background:white;
    border-radius:12px;
    padding:15px;
    height:320px;
  }

  canvas {
    width:100%!important;
    height:250px!important;
  }
  </style>
  </head>

  <body>

  <div class="header">
    <div class="title">📊 Dashboard Report</div>
    <div>Generated: <%= new Date().toLocaleString() %></div>
  </div>

  <!-- KPI -->
  <div class="kpi-container">
  <% charts.filter(c => c.type==="KPI").forEach(c => { %>
    <% Object.entries(c.data || {}).forEach(([k,v]) => { %>
      <div class="kpi">
        <small><%= k %></small><br/>
        <strong><%= v %></strong>
      </div>
    <% }) %>
  <% }) %>
  </div>

  <!-- CHARTS -->
  <div class="dashboard">
  <% charts.forEach((chart,index)=>{ %>
  <% if(chart.type !== "KPI"){ %>

  <div class="chart-box">
  <h4><%= chart.title %></h4>

  <% if(!chart.data || chart.data.length===0){ %>
    <p>No Data</p>
  <% } else { %>
    <canvas id="chart<%=index%>"></canvas>
  <% } %>

  </div>

  <% } %>
  <% }) %>
  </div>

  <script>
  window.chartRendered = false;

  const chartPromises = [];

  <% charts.forEach((chart,index)=>{ %>
  <% if(chart.type !== "KPI" && chart.data && chart.data.length){ %>

  chartPromises.push(new Promise(resolve => {
    try {

      let chartInstance;

      if ("<%= chart.type %>" === "LINE") {
        const labels = <%- JSON.stringify(chart.data.map(d=>d.x)) %>;
        const keys = Object.keys(chart.data[0]).filter(k=>k!=="x");

        const datasets = keys.map(k=>({
          label:k,
          data: chart.data.map(d=>d[k]),
          borderWidth:2
        }));

        chartInstance = new Chart(document.getElementById("chart<%=index%>"),{
          type:"line",
          data:{labels,datasets}
        });
      }

      else if ("<%= chart.type %>" === "SCATTER") {
        chartInstance = new Chart(document.getElementById("chart<%=index%>"),{
          type:"scatter",
          data:{datasets:[{data:<%- JSON.stringify(chart.data)%>}]}
        });
      }

      else {
        chartInstance = new Chart(document.getElementById("chart<%=index%>"),{
          type:"bar",
          data:{
            labels:<%- JSON.stringify(chart.data.map(d=>d.name||"")) %>,
            datasets:[{data:<%- JSON.stringify(chart.data.map(d=>d.value||0)) %>}]
          }
        });
      }

      setTimeout(resolve, 500); // allow render

    } catch(e){
      resolve();
    }
  }));

  <% } %>
  <% }) %>

  Promise.all(chartPromises).then(()=>{
    window.chartRendered = true;
  });
  </script>

  </body>
  </html>