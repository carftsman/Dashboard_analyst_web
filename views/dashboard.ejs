<!DOCTYPE html>
<html>
<head>
<script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

<style>
body {
  font-family: 'Segoe UI';
  background: #f4f6f9;
  padding: 20px;
}

/* HEADER */
.header {
  display:flex;
  justify-content:space-between;
  margin-bottom:20px;
}

.title { font-size:26px; font-weight:600; }

/* KPI */
.kpi-container {
  display:grid;
  grid-template-columns: repeat(5,1fr);
  gap:10px;
  margin-bottom:20px;
}

.kpi {
  background:white;
  border-left:5px solid #0078d4;
  padding:10px;
  border-radius:8px;
}

.kpi small { color:#666; }
.kpi strong { font-size:16px; }

/* CHART GRID */
.dashboard {
  display:grid;
  grid-template-columns: repeat(2,1fr);
  gap:20px;
}

.chart-box {
  background:white;
    page-break-inside: avoid;   /* 🔥 CRITICAL */
  break-inside: avoid;

  border-radius:12px;
  padding:15px;
  height:320px;
}

canvas {
  width:100%!important;
  height:3000px!important;
}
</style>
</head>

<body>

<div class="header">
  <div class="title">📊 Dashboard Report</div>
  <div>Generated: <%= new Date().toLocaleString() %></div>
</div>

<!-- KPI -->
<div class="kpi-container">
<% charts.filter(c => c.type === "KPI").forEach(c => { %>
  <% Object.entries(c.data || {}).forEach(([k,v]) => { %>
    <div class="kpi">
      <small><%= k %></small><br/>
      <strong><%= Number(v).toLocaleString() %></strong>
    </div>
  <% }) %>
<% }) %>
</div>

<!-- CHARTS -->
<div class="dashboard">
<% charts.forEach((chart,index)=>{ %>
<% if(chart.type !== "KPI"){ %>

<div class="chart-box">
<h4><%= chart.title %></h4>

<% if(
  !chart.data || 
  (Array.isArray(chart.data) && chart.data.length === 0)
){ %>
<p style="text-align:center;color:#999;margin-top:100px;">
  No meaningful data available
</p><% } else { %>
 <% if(chart.image){ %>
  <img src="<%= chart.image %>" style="width:100%;height:250px;" />
<% } else { %>
  <p>No Data</p>
<% } %>
<% } %>

</div>

<% } %>
<% }) %>
</div>

<script>
window.chartRendered = false;
const chartPromises = [];

<% charts.forEach((chart,index)=>{ %>
<% if(chart.type !== "KPI" && chart.data && chart.data.length){ %>

chartPromises.push(new Promise(resolve => {
  try {

    const ctx = document.getElementById("chart<%=index%>");
    if (!ctx) return resolve();

    let chartInstance;
    const type = "<%= chart.type %>".toLowerCase();

    //////////////////////////////////////////////////////
    // LINE / AREA / STACKED
    //////////////////////////////////////////////////////
    if (type === "line" || type === "area" || type === "stacked"){

      const labels = <%- JSON.stringify(chart.data.map(d => d.x || "Unknown")) %>;
      const keys = Object.keys(chart.data[0] || {}).filter(k => k !== "x");

      const datasets = keys.map((k, i) => ({
        label: k,
        data: chart.data.map(d => Number(String(d[k]).replace(/,/g,'')) || 0),
        borderWidth: 2,
        borderColor: `hsl(${i * 60}, 70%, 50%)`,
        backgroundColor: `hsla(${i * 60}, 70%, 50%, 0.3)`,
        fill: type !== "line"
      }));

      chartInstance = new Chart(ctx, {
        type: "line",
        data: { labels, datasets },
        options: {
          responsive: true,
          animation: false, // 🔥 IMPORTANT
          plugins: { legend: { position: "bottom" } }
        }
      });
    }

    //////////////////////////////////////////////////////
    // SCATTER
    //////////////////////////////////////////////////////
    else if (type === "scatter"){

      const cleanData = <%- JSON.stringify(chart.data.filter(d => d.x !== undefined && d.y !== undefined)) %>;

      chartInstance = new Chart(ctx, {
        type: "scatter",
        data: {
          datasets: [{
            label: "Scatter",
            data: cleanData,
            backgroundColor: "#0078d4"
          }]
        },
        options: {
          animation: false // 🔥 IMPORTANT
        }
      });
    }

    //////////////////////////////////////////////////////
    // PIE / DONUT
    //////////////////////////////////////////////////////
    else if (type === "pie" || type === "donut") {

      const labels = <%- JSON.stringify(chart.data.map(d => d.name || "Unknown")) %>;
      const keys = Object.keys(chart.data[0] || {}).filter(k => k !== "name");

      const datasets = keys.map((k, i) => ({
        label: k,
        data: chart.data.map(d => Number(String(d[k]).replace(/,/g,'')) || 0),
        backgroundColor: `hsl(${i * 50},70%,60%)`
      }));

      chartInstance = new Chart(ctx, {
        type: "pie",
        data: { labels, datasets },
        options: {
          animation: false // 🔥 IMPORTANT
        }
      });
    }

    //////////////////////////////////////////////////////
    // BAR (DEFAULT)
    //////////////////////////////////////////////////////
    else {

      const labels = <%- JSON.stringify(chart.data.map(d => d.name || "Unknown")) %>;
      const keys = Object.keys(chart.data[0] || {}).filter(k => k !== "name");

      const datasets = keys.map((k, i) => ({
        label: k,
        data: chart.data.map(d => Number(String(d[k]).replace(/,/g,'')) || 0),
        backgroundColor: `hsl(${i * 60},70%,60%)`
      }));

      chartInstance = new Chart(ctx, {
        type: "bar",
        data: { labels, datasets },
        options: {
          responsive: true,
          animation: false, // 🔥 IMPORTANT
          plugins: { legend: { position: "bottom" } }
        }
      });
    }

    //////////////////////////////////////////////////////
    // 🔥 FORCE RENDER COMPLETE
    //////////////////////////////////////////////////////
    chartInstance.update();

    // wait for canvas paint
    setTimeout(() => {
      resolve();
    }, 2500); // 🔥 stable delay

  } catch (e) {
    console.error("Chart Error:", e);
    resolve();
  }
}));

<% } %>
<% }) %>

Promise.all(chartPromises).then(()=>{
  window.chartRendered = true;
});
</script>

</body>
</html>