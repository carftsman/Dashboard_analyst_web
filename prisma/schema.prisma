generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  fullName            String
  email               String               @unique
  password            String
  role                UserRole
  status              AccountStatus        @default(ACTIVE)
  createdById         Int?
  lastLoginAt         DateTime?
  isLoggedIn          Boolean              @default(false)
  isDeleted           Boolean              @default(false)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  dashboards          Dashboard[]
  schemaChanges       DataSchema[]
  passwordResetTokens PasswordResetToken[]
  reports             Report[]
  uploadedFiles       UploadedFile[]
  createdBy           User?                @relation("UserCreatedUsers", fields: [createdById], references: [id])
  createdUsers        User[]               @relation("UserCreatedUsers")

  @@map("users")
}

model PasswordResetToken {
  id        Int      @id @default(autoincrement())
  userId    Int
  expiresAt DateTime
  used      Boolean  @default(false)
  createdAt DateTime @default(now())
  otp       String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model DataSchema {
  id           Int      @id @default(autoincrement())
  schemaName   String
  tableName    String?
  columnName   String
  dataType     String
  isRequired   Boolean  @default(false)
  defaultValue String?
  description  String?
  isActive     Boolean  @default(true)
  updatedById  Int
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  updatedBy    User     @relation(fields: [updatedById], references: [id])

  @@index([schemaName])
  @@index([tableName])
  @@map("data_schemas")
}

model Report {
  id            Int           @id @default(autoincrement())
  title         String
  reportType    ReportType
  description   String?
  fileId        Int?
  generatedById Int
  createdAt     DateTime      @default(now())
  file          UploadedFile? @relation(fields: [fileId], references: [id])
  generatedBy   User          @relation(fields: [generatedById], references: [id])

  @@map("reports")
}

model Dashboard {
  dashboardId   Int               @id @default(autoincrement())
  dashboardName String
  category      DashboardCategory
  description   String?
  status        DashboardStatus   @default(ACTIVE)
  createdById   Int
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  widgets       DashboardWidget[]
  createdBy     User              @relation(fields: [createdById], references: [id], onDelete: Cascade)
  uploads       UploadedFile[]

  @@index([createdById])
  @@index([category])
  @@map("dashboards")
}

model UploadedFile {
  id              Int               @id @default(autoincrement())
  fileName        String
  fileUrl         String?
  status          FileStatus        @default(UPLOADED)
  dashboardId     Int?
  uploadedById    Int
  uploadedColumns Json?
  extraColumns    Json?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  widgets         DashboardWidget[]
  rows            DataRow[]
  reports         Report[]
  dashboard       Dashboard?        @relation(fields: [dashboardId], references: [dashboardId], onDelete: Cascade)
  uploadedBy      User              @relation(fields: [uploadedById], references: [id])

  @@index([dashboardId])
  @@index([uploadedById])
  @@map("uploaded_files")
}

model DataRow {
  id         Int               @id @default(autoincrement())
  fileId     Int
  rowData    Json
  status     RowStatus
  createdAt  DateTime          @default(now())
  file       UploadedFile      @relation(fields: [fileId], references: [id], onDelete: Cascade)
  validation ValidationResult?

  @@index([fileId])
  @@map("data_rows")
}

model ValidationResult {
  id        Int      @id @default(autoincrement())
  rowId     Int      @unique
  errors    Json
  isValid   Boolean
  createdAt DateTime @default(now())
  row       DataRow  @relation(fields: [rowId], references: [id], onDelete: Cascade)

  @@map("validation_results")
}

model DashboardWidget {
  id          Int           @id @default(autoincrement())
  dashboardId Int
  title       String
  widgetType  WidgetType
  positionX   Int
  positionY   Int
  width       Int
  height      Int
  fileId      Int?
  config      Json
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  dashboard   Dashboard     @relation(fields: [dashboardId], references: [dashboardId], onDelete: Cascade)
  file        UploadedFile? @relation(fields: [fileId], references: [id])

  @@index([dashboardId])
  @@map("dashboard_widgets")
}

enum UserRole {
  ADMIN
  MANAGER
  ANALYST
  SUB_USER
  USER
}

enum AccountStatus {
  ACTIVE
  INACTIVE
}

enum ReportType {
  DAILY
  WEEKLY
  MONTHLY
  CUSTOM
}

enum DashboardCategory {
  SALES
  MARKETING
  SUPPLY_CHAIN
  FINANCE
  HR
  OPERATIONS
  CUSTOM
}

enum DashboardStatus {
  ACTIVE
  INACTIVE
}

enum FileStatus {
  UPLOADED
  VALIDATED
  FAILED
}

enum RowStatus {
  VALID
  INVALID
}

enum WidgetType {
  KPI_CARDS
  BAR_CHART
  PIE_CHART
  LINE_CHART
  GAUGE_CHART
  MAP_CHART
  STACKED_CHART
  SCATTER_PLOT
  TABLE
}
